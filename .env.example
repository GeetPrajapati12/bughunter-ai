# ── BugHunter AI — Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Only ONE AI provider section is needed — fill in the one you have.

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | gemini | groq | ollama
AI_PROVIDER=anthropic

# ── AI Model ──────────────────────────────────────────────────────────────────
# Set the model name that matches your chosen provider:
#
#   anthropic  → claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
#   openai     → gpt-4o | gpt-4-turbo | gpt-3.5-turbo
#   gemini     → gemini-1.5-pro | gemini-1.5-flash
#   groq       → llama3-70b-8192 | mixtral-8x7b-32768 | gemma-7b-it
#   ollama     → llama3 | mistral | phi3 (any model you have pulled locally)
#
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2

# ── API Keys ──────────────────────────────────────────────────────────────────
# Only fill in the key for your chosen AI_PROVIDER. Leave others blank.

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (free tier available) — https://console.groq.com
GROQ_API_KEY=

# Ollama (local, no key needed) — https://ollama.com
# Make sure Ollama is running: ollama serve
# Pull a model first: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER_ENGINE=selenium
BROWSER_HEADLESS=true
BROWSER_WINDOW_WIDTH=1366
BROWSER_WINDOW_HEIGHT=768
PAGE_LOAD_TIMEOUT=30
IMPLICIT_WAIT=5
ELEMENT_TIMEOUT=10

# ── Crawler ───────────────────────────────────────────────────────────────────
MAX_PAGES=50
MAX_DEPTH=3
CRAWL_DELAY_SECONDS=1.0
RESPECT_ROBOTS_TXT=true

# ── Reporting ─────────────────────────────────────────────────────────────────
REPORT_FORMAT=html
SCREENSHOT_ON_FAIL=true
CAPTURE_VIDEO=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
